*.swp
*.swo
.DS_Store
Thumbs.db

# ---> Personal / local config
# Anything under these directories is treated as user-private and never committed.
# Useful for local notes, ad-hoc scripts, deployment helpers, or private overrides.
local/
private/
secrets/
.local/
*.local
