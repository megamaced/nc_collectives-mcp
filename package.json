{
  "name": "collectives-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Model Context Protocol server for Nextcloud Collectives",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "collectives-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx 'src/**/*.test.ts'",
    "prepublishOnly": "tsc",
    "pack:tarball": "tsc && npm pack"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
